# Pflicht: Passwort für den Login zur Weboberfläche.
ADMIN_PASSWORD=

# Optional. Siehe README.md für die vollständige Liste und Standardwerte.
# HOST=0.0.0.0
# PORT=8080
# CONFIG_DIR=/config
# DOWNLOADS_DIR=/downloads
# LOG_LEVEL=info

# Optional: 64 Hex-Zeichen (32 Byte). Ohne Angabe wird beim ersten Start
# ein Schlüssel generiert und in CONFIG_DIR abgelegt.
# ENCRYPTION_KEY=
