# Normalize line endings to LF in the repository and working tree.
# Biome's formatter expects LF; without this, Git's autocrlf turns checked-out
# files into CRLF on Windows and `npm run lint` fails locally though the
# committed blobs are already LF.
* text=auto eol=lf

# Binary files must never be normalized.
*.png binary
*.pdf binary
*.sqlite binary
