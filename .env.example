# Required: password for logging into the web UI.
ADMIN_PASSWORD=

# Optional. See README.md for the full list and default values.
# HOST=0.0.0.0
# PORT=8080
# CONFIG_DIR=/config
# DOWNLOADS_DIR=/downloads
# LOG_LEVEL=info

# Optional: 64 hex characters (32 bytes). If omitted, a key is generated
# on first start and stored in CONFIG_DIR.
# ENCRYPTION_KEY=
